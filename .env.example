# --- Database (Postgres) ---
# Connection string used by Drizzle + better-auth.
DATABASE_URL=postgres://user:password@host:5432/dbname

# --- Auth (better-auth) ---
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-a-long-random-string

# Optional. If unset, the app derives the URL from Vercel/VERCEL_URL env vars.
# BETTER_AUTH_URL=https://your-domain.com

# --- Google sign-in ---
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <your-base-url>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Client-side mirror of GOOGLE_CLIENT_ID (only used to know whether to render
# the Google button). Falls back to GOOGLE_CLIENT_ID if not set.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
